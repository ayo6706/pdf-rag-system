# ── Infrastructure ───────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://your_username:your_secure_password@db:5432/pdf_kb
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
CHROMA_HOST=chroma
CHROMA_PORT=8000
APP_ENV=development
# Production must provide a secret-backed password in this URL.
REDIS_URL=redis://:REPLACE_ME@redis:6379/0
INGESTION_QUEUE_NAME=ingestion

# ── LLM Provider API Keys ───────────────────────────────
# Set the key for the provider you want to use.
# LiteLLM reads these automatically — only set the one(s) you need.
GOOGLE_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Model Configuration ─────────────────────────────────
# Use LiteLLM model format: "provider/model-name"
# Google Gemini:  DEFAULT_LLM_MODEL=gemini/gemini-2.5-flash
#                 DEFAULT_EMBEDDING_MODEL=gemini/gemini-embedding-001
# OpenAI:         DEFAULT_LLM_MODEL=gpt-4o
#                 DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
# Anthropic:      DEFAULT_LLM_MODEL=claude-sonnet-4-20250514
#                 DEFAULT_EMBEDDING_MODEL=  (use OpenAI or Google for embeddings)
DEFAULT_LLM_MODEL=gemini/gemini-2.5-flash
DEFAULT_EMBEDDING_MODEL=gemini/gemini-embedding-001
